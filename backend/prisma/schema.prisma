generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  CUSTOMER
  ADMIN
  SUPER_ADMIN
}

enum ServiceType {
  SURFACE
  AIR
  WATER
  EXPRESS
}

enum PaymentType {
  PREPAID
  TO_PAY
  TO_BILL
  COD
}

enum PackageType {
  PACKAGES
  BOXES
  BAGS
  PACKETS
}

enum ConsignmentType {
  OUTBOUND
  INBOUND
  RETURN
}

enum DimensionUnit {
  INCHES
  CMS
}

enum PickupOption {
  PICKUP_FROM_CONSIGNOR
  DROP_AT_BRANCH
}

enum OrderStatus {
  PENDING
  ASSIGNED
  BOOKED
  IN_TRANSIT
  OUT_FOR_DELIVERY
  DELIVERED
  EXCEPTION
  CANCELLED
}

enum PartnerName {
  DELHIVERY
  DP_WORLD
  VRL
  DTDC
  MANUAL
}

enum TrackingSource {
  API
  MANUAL
}

enum InvoiceStatus {
  DRAFT
  SENT
  PAID
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  company   String?
  gstin     String?
  phone     String?
  role      Role     @default(CUSTOMER)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  addresses       Address[]
  orders          Order[]
  invoices        Invoice[]
  adminRole       AdminRole?
  bookedShipments Shipment[] @relation("BookedByAdmin")
}

model Address {
  id           String  @id @default(uuid())
  userId       String
  label        String
  companyName  String?
  contactName  String
  phone        String
  email        String?
  addressLine1 String
  addressLine2 String?
  city         String
  state        String
  pincode      String
  isDefault    Boolean  @default(false)
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Order {
  id             String      @id @default(uuid())
  clientDocketNo String      @unique
  userId         String?
  isDirectBooking Boolean    @default(false)

  // Consignor Details
  consignorName         String?
  consignorPin          String?
  consignorAddressLine1 String?
  consignorAddressLine2 String?
  consignorCity         String?
  consignorState        String?
  consignorContactPerson String?
  consignorPhone        String?
  consignorEmail        String?

  // Consignee Details
  consigneeName         String?
  consigneePin          String?
  consigneeAddressLine1 String?
  consigneeAddressLine2 String?
  consigneeCity         String?
  consigneeState        String?
  consigneeContactPerson String?
  consigneePhone        String?
  consigneeEmail        String?

  // Service & Delivery Options
  serviceType         ServiceType
  appointmentDelivery Boolean     @default(false)
  carrierRisk         Boolean     @default(false)
  ownersRisk          Boolean     @default(false)
  mallDelivery        Boolean     @default(false)

  // Weight & Item Details
  actualWeight   Float?
  itemDescription String?
  packages       Int?
  packagesType   PackageType   @default(BAGS)
  unitWeight     Float?
  dimensionL     Float?
  dimensionW     Float?
  dimensionH     Float?
  dimensionUnit  DimensionUnit @default(CMS)

  // Payment
  paymentType  PaymentType
  codPayeeName String?
  codAmount    Float?

  // Invoice / Commercial Details
  invoiceValue Float?
  invoiceNo    String?
  invoiceDate  DateTime?
  ewayBillNo   String?
  hsnCode      String?
  quantity     Int?

  // Booking Meta
  consignmentType      ConsignmentType?
  requestedBy          String?
  consignorCountryCode String           @default("+91")
  consigneeCountryCode String           @default("+91")
  promoCode            String?

  // Notes
  notes String?

  // Legacy fields (kept for backward compat)
  pickupAddressSnapshot   Json?
  deliveryAddressSnapshot Json?
  commodity               String?
  weight                  Float?
  dimensions              Json?
  declaredValue           Float?
  specialInstructions     String?

  status    OrderStatus @default(PENDING)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  user     User?       @relation(fields: [userId], references: [id])
  shipment Shipment?
  items    OrderItem[]
}

model Shipment {
  id              String       @id @default(uuid())
  orderId         String       @unique
  partnerName     PartnerName
  partnerDocketNo String?
  loginId         String?
  docketDate      DateTime?
  pickupOption    PickupOption?
  billToParty     String?
  materialHold    Boolean      @default(false)
  waitingPermit   Boolean      @default(false)
  deliveryCode    String?
  checkedRates    Json?
  bookingResponse Json?
  bookedAt        DateTime?
  bookedByAdminId String?

  order         Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  bookedByAdmin User?           @relation("BookedByAdmin", fields: [bookedByAdminId], references: [id])
  trackingEvents TrackingEvent[]
}

model TrackingEvent {
  id          String         @id @default(uuid())
  shipmentId  String
  status      String
  description String
  location    String?
  timestamp   DateTime
  source      TrackingSource @default(MANUAL)
  createdAt   DateTime       @default(now())

  shipment Shipment @relation(fields: [shipmentId], references: [id], onDelete: Cascade)
}

model Invoice {
  id          String        @id @default(uuid())
  invoiceNo   String        @unique
  userId      String
  dateFrom    DateTime
  dateTo      DateTime
  lineItems   Json
  subtotal    Float
  tax         Float
  totalAmount Float
  pdfUrl      String?
  status      InvoiceStatus @default(DRAFT)
  createdAt   DateTime      @default(now())
  sentAt      DateTime?

  user User @relation(fields: [userId], references: [id])
}

model MISReport {
  id         String    @id @default(uuid())
  reportDate DateTime
  pdfUrl     String?
  sentAt     DateTime?
  createdAt  DateTime  @default(now())
}

model AdminRole {
  id          String   @id @default(uuid())
  userId      String   @unique
  permissions Json
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PartnerCredential {
  id          String      @id @default(uuid())
  partner     PartnerName @unique
  loginId     String?
  apiKey      String?
  apiSecret   String?
  baseUrl     String?
  extraConfig Json?
  updatedAt   DateTime    @updatedAt
}

model OrderItem {
  id            String  @id @default(uuid())
  orderId       String
  description   String?
  reference     String?
  packages      Int?
  packagesType  String  @default("BAGS")
  unitWeight    Float?
  dimensionL    Float?
  dimensionW    Float?
  dimensionH    Float?
  dimensionUnit String  @default("CMS")

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

model SavedConsignor {
  id            String   @id @default(uuid())
  name          String
  pin           String?
  addressLine1  String?
  addressLine2  String?
  city          String?
  state         String?
  contactPerson String?
  countryCode   String   @default("+91")
  phone         String?
  email         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model SavedConsignee {
  id            String   @id @default(uuid())
  name          String
  pin           String?
  addressLine1  String?
  addressLine2  String?
  city          String?
  state         String?
  contactPerson String?
  countryCode   String   @default("+91")
  phone         String?
  email         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Counter {
  id    String @id
  value Int    @default(0)
}
